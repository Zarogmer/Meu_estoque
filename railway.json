{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build && cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static"
  },
  "deploy": {
    "preDeployCommand": "node scripts/migrate-profile-fields.js",
    "startCommand": "node .next/standalone/server.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
